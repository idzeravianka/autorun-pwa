{
  "name": "autorun-pwa",
  "version": "0.1.0",
  "author": "Nobody Knows",
  "HomePageComponent": "https://github.com/idzeravianka/autorun-pwa",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --poll 2000 --host 0.0.0.0",
    "build": "ng build --configuration production --base-href /autorun-pwa/",
    "deploy-to-gh": "npx angular-cli-ghpages --dir=www --no-silent",
    "deploy": "ng deploy --base-href=/autorun-pwa/",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "ng lint",
    "lint:fix": "ng lint --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.0.0",
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.0",
    "@angular/platform-browser": "^21.0.0",
    "@angular/platform-browser-dynamic": "^21.0.0",
    "@angular/router": "^21.0.0",
    "@angular/service-worker": "^21.0.0",
    "@ionic/angular": "^8.0.0",
    "ionicons": "^8.0.0",
    "ng-circle-progress": "^1.7.1",
    "paho-mqtt": "^1.1.0",
    "rxjs": "~7.8.0",
    "swiper": "^12.1.3",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.0.0",
    "@angular-eslint/builder": "^21.0.0",
    "@angular-eslint/eslint-plugin": "^21.0.0",
    "@angular-eslint/eslint-plugin-template": "^21.0.0",
    "@angular-eslint/schematics": "^21.0.0",
    "@angular-eslint/template-parser": "^21.0.0",
    "@angular/cli": "^21.0.0",
    "@angular/compiler-cli": "^21.0.0",
    "@angular/language-service": "^21.0.0",
    "@ionic/angular-toolkit": "^12.0.0",
    "@types/jasmine": "~5.1.0",
    "@types/paho-mqtt": "^1.0.10",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "angular-cli-ghpages": "^3.0.3",
    "eslint": "^9.16.0",
    "eslint-config-prettier": "^10.1.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsdoc": "^48.11.0",
    "eslint-plugin-prefer-arrow": "^1.2.3",
    "jasmine-core": "~5.1.0",
    "jasmine-spec-reporter": "~5.0.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "prettier": "^3.6.2",
    "typescript": "~5.9.0"
  },
  "description": "Engine Autorun Application"
}
